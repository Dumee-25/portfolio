---
// Claims carry receipts (design report §1.1): no strong sentence without a
// link to the thing that backs it. Academic citation, but for engineering.
interface Props {
  href: string;
  receipt: string; // short label for the proof, e.g. "repo", "bench", "paper"
}
const { href, receipt } = Astro.props;
---

<span class="claim"
  ><slot /><a class="claim__receipt" href={href} rel="noopener" title={`receipt: ${receipt}`}
    >{receipt}</a
  ></span
>

<style>
  .claim {
    border-bottom: 1px solid var(--rule);
  }
  .claim__receipt {
    font-family: var(--font-ui);
    font-size: 0.7em;
    vertical-align: super;
    line-height: 0;
    margin-left: 0.15em;
    color: var(--signal);
    text-decoration: none;
    white-space: nowrap;
  }
  .claim__receipt::before {
    content: '↳';
    margin-right: 0.1em;
  }
  .claim__receipt:hover {
    text-decoration: underline;
  }
</style>
