---
// "What this does not do" — open by default, above the fold, in the color for
// honesty. (design report §1.2). Surfacing weakness reads as confidence.
interface Props {
  items: string[];
  heading?: string;
  failureModes?: string[];
}
const { items, heading = 'What this does not do', failureModes } = Astro.props;
---

<section class="flagbox" aria-label={heading}>
  <h3 class="flagbox__head">{heading}</h3>
  <ul class="flagbox__list">
    {items.map((item) => <li>{item}</li>)}
  </ul>
  {
    failureModes && failureModes.length > 0 && (
      <>
        <h3 class="flagbox__head flagbox__head--sub">How it fails</h3>
        <ul class="flagbox__list">
          {failureModes.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </>
    )
  }
</section>

<style>
  .flagbox {
    border: 1px solid color-mix(in srgb, var(--flag) 35%, var(--rule));
    border-left: 3px solid var(--flag);
    background: var(--flag-tint);
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-5);
    margin-block: var(--space-5);
  }
  .flagbox__head {
    margin: 0 0 var(--space-2);
    font-size: var(--step-0);
    font-family: var(--font-mono);
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--flag);
  }
  .flagbox__head--sub {
    margin-top: var(--space-4);
  }
  .flagbox__list {
    margin: 0;
    padding-left: 1.2em;
    color: var(--ink);
  }
  .flagbox__list li {
    margin-top: var(--space-1);
  }
  .flagbox__list li::marker {
    color: var(--flag);
  }
</style>
