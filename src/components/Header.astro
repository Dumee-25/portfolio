---
import { nav, site } from '../site';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="site-head">
  <div class="wrap site-head__inner">
    <a href="/" class="brand" aria-label={`${site.name} — home`}>
      <span class="brand__mark" aria-hidden="true"></span>
      <span class="brand__name">{site.name}</span>
    </a>
    <div class="site-head__right">
      <nav aria-label="Primary">
        <ul>
          {
            nav.map((item) => (
              <li>
                <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">
        <svg class="theme-toggle__sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"></path>
        </svg>
        <svg class="theme-toggle__moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var next =
        document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      try {
        localStorage.setItem('theme', next);
      } catch (e) {}
    });
  })();
</script>

<style>
  .site-head {
    border-bottom: var(--border-hair);
    background: var(--paper);
  }
  .site-head__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-4);
    flex-wrap: wrap;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    font-weight: 600;
  }
  .brand__name {
    letter-spacing: -0.01em;
  }
  .brand__mark {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: var(--signal);
    flex: none;
  }
  nav ul {
    list-style: none;
    display: flex;
    gap: var(--space-5);
    padding: 0;
    margin: 0;
    font-family: var(--font-ui);
    font-size: var(--step--1);
  }
  nav a {
    text-decoration: none;
    color: var(--muted);
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
  }
  nav a:hover {
    color: var(--ink);
  }
  nav a[aria-current='page'] {
    color: var(--ink);
    border-bottom-color: var(--signal);
  }
  .site-head__right {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    color: var(--muted);
    background: transparent;
    border: var(--border-hair);
    border-radius: var(--radius);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .theme-toggle:hover {
    color: var(--ink);
    border-color: var(--signal);
  }
  /* Show the icon for the mode you'd switch TO. */
  .theme-toggle__sun {
    display: none;
  }
  :global(:root[data-theme='dark']) .theme-toggle__moon {
    display: none;
  }
  :global(:root[data-theme='dark']) .theme-toggle__sun {
    display: block;
  }
</style>
